{
  "name": "prayer-app",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "provision:user": "node scripts/provision-supabase-user.mjs",
    "cap:sync": "npm run build && npx cap sync",
